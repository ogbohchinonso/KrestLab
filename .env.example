# ── KrestLab Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in real values. NEVER commit .env to git.

# Server
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:3000

# MongoDB
MONGO_URI=mongodb://localhost:27017/krestlab

# Auth
JWT_SECRET=your_32_byte_hex_secret
JWT_EXPIRES_IN=7d

# DeepSeek (AI Tutor)
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Judge0 (self-hosted code execution)
# Set any token string — this secures your Judge0 instance
JUDGE0_AUTH_TOKEN=your_32_byte_hex_secret
JUDGE0_URL=http://localhost:2358

# Judge0 internal DB/Redis passwords (for docker-compose)
JUDGE0_DB_PASSWORD=judge0pass
REDIS_PASSWORD=judge0redis

# Stripe (wired but not enforced — ready for when you monetize)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
